#!/usr/bin/env bash
set -euo pipefail
export AI_PEERS_CLIENT="cursor-agent"
export AI_PEERS_ROLE="hard-programmer"
export AI_PEERS_SESSION_KEY="${AI_PEERS_SESSION_KEY:-$(uuidgen | tr '[:upper:]' '[:lower:]' | tr -d '-')}"
export AI_PEERS_LAUNCH_CWD="${PWD}"
export AI_PEERS_SUMMARY="${AI_PEERS_SUMMARY:-Cursor hard-task implementer}"
exec agent "$@"
