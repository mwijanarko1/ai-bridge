#!/usr/bin/env bash
set -euo pipefail

ROOT="${AI_BRIDGE_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
export PYTHONPATH="${ROOT}/src${PYTHONPATH:+:$PYTHONPATH}"
PYTHON_BIN="${AI_BRIDGE_PEERS_PYTHON:-python3}"

if [[ -n "${AI_BRIDGE_PEERS_CLI:-}" ]]; then
  exec "$PYTHON_BIN" "$AI_BRIDGE_PEERS_CLI" "$@"
fi

exec "$PYTHON_BIN" -m ai_peers.cli "$@"
