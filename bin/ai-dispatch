#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import re
import signal
import shutil
import subprocess
import sys
import tempfile
import time
import uuid
from pathlib import Path
from typing import Any

STATE_ROOT = Path("~/.local/state/ai-dispatch").expanduser()
JOBS_DIR = STATE_ROOT / "jobs"
LOGS_DIR = STATE_ROOT / "logs"
CONFIG_DIR = Path("~/.config/ai-bridge").expanduser()
ADAPTERS_FILE = Path(os.environ.get("AI_BRIDGE_ADAPTERS_FILE", str(CONFIG_DIR / "adapters.json"))).expanduser()
DEFAULT_TIMEOUT = 900
BUILTIN_TARGETS = {"codex", "claude", "opencode", "cursor", "goose"}
TARGET_ALIASES = {
    "openai-codex-cli": "codex",
    "codex-cli": "codex",
    "claude-code": "claude",
    "cursor-agent": "cursor",
    "agent": "cursor",
    "goose-cli": "goose",
    "gemini-cli": "gemini",
}


def ensure_state_root() -> None:
    JOBS_DIR.mkdir(parents=True, exist_ok=True)
    LOGS_DIR.mkdir(parents=True, exist_ok=True)


def now_ts() -> float:
    return time.time()


def detect_repo_root(cwd: str) -> str | None:
    try:
        result = subprocess.run(
            ["git", "-C", cwd, "rev-parse", "--show-toplevel"],
            check=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
        value = result.stdout.strip()
        return value or None
    except Exception:
        return None


def build_prompt(user_prompt: str, difficulty: str, cwd: str, source: str, target: str) -> str:
    return (
        f"You are being invoked as a delegated worker from {source}.\n"
        f"Target worker: {target}.\n"
        f"Task difficulty lane: {difficulty}.\n"
        f"Working directory: {cwd}\n"
        "Do the work directly if it is feasible. If you cannot complete it safely, "
        "say clearly that you could not complete it and why. Be concise.\n\n"
        f"User task:\n{user_prompt.strip()}\n"
    )


def normalize_target(target: str) -> str:
    clean = str(target or "").strip().lower()
    return TARGET_ALIASES.get(clean, clean)


def load_adapter_config() -> dict[str, Any]:
    if not ADAPTERS_FILE.exists():
        return {}
    try:
        return json.loads(ADAPTERS_FILE.read_text(encoding="utf-8"))
    except Exception:
        return {}


def render_adapter_command(template: list[str], *, prompt: str, cwd: str, source: str, target: str, difficulty: str) -> list[str]:
    rendered: list[str] = []
    replacements = {
        "{prompt}": prompt,
        "{cwd}": cwd,
        "{source}": source,
        "{target}": target,
        "{difficulty}": difficulty,
    }
    for token in template:
        value = str(token)
        for needle, replacement in replacements.items():
            value = value.replace(needle, replacement)
        rendered.append(value)
    return rendered


def builtin_worker_command(worker: str, prompt: str, cwd: str) -> list[str]:
    if worker == "codex":
        return [
            "codex",
            "exec",
            "--skip-git-repo-check",
            "--full-auto",
            "--cd",
            cwd,
            prompt,
        ]
    if worker == "claude":
        return [
            "claude-code-worker",
            "-p",
            "--permission-mode",
            "bypassPermissions",
            "--add-dir",
            cwd,
            "--",
            prompt,
        ]
    if worker == "goose":
        return [
            "goose",
            "run",
            "--text",
            prompt,
        ]
    if worker == "opencode":
        return [
            "opencode-easy",
            "run",
            "--dir",
            cwd,
            "--dangerously-skip-permissions",
            prompt,
        ]
    if worker == "cursor":
        return [
            "agent-hard",
            "--print",
            "--output-format",
            "text",
            "--trust",
            "--force",
            "--approve-mcps",
            "--workspace",
            cwd,
            prompt,
        ]
    raise ValueError(f"Unknown worker '{worker}'")


def worker_command(worker: str, prompt: str, cwd: str, source: str, difficulty: str) -> list[str]:
    normalized = normalize_target(worker)
    if normalized in BUILTIN_TARGETS:
        return builtin_worker_command(normalized, prompt, cwd)

    adapters = load_adapter_config()
    adapter = adapters.get(normalized) or adapters.get(worker)
    if not adapter:
        raise ValueError(
            f"Unsupported target '{worker}'. Add an adapter in {ADAPTERS_FILE} "
            "or use one of the built-in targets: codex, claude, cursor, opencode, goose."
        )

    command = adapter.get("command")
    if not isinstance(command, list) or not command:
        raise ValueError(f"Adapter '{worker}' is missing a non-empty command list.")

    binary = str(command[0])
    resolved = shutil.which(binary) if not os.path.isabs(binary) else binary
    if not resolved:
        raise ValueError(f"Adapter '{worker}' command '{binary}' is not available on PATH.")

    return render_adapter_command(
        command,
        prompt=prompt,
        cwd=cwd,
        source=source,
        target=normalized,
        difficulty=difficulty,
    )


def normalize_difficulty(raw: str, task: str) -> str:
    if raw != "auto":
        return raw
    lowered = task.lower()
    hard_markers = [
        "debug",
        "refactor",
        "architecture",
        "migration",
        "race condition",
        "performance",
        "hard",
        "complex",
        "multi-file",
        "multi step",
        "distributed",
        "concurrency",
        "security",
    ]
    return "hard" if any(marker in lowered for marker in hard_markers) else "easy"


def route_for(target: str, difficulty: str) -> list[str]:
    normalized = normalize_target(target)
    if normalized != "auto":
        return [normalized]
    return ["opencode", "cursor"] if difficulty == "easy" else ["cursor", "opencode"]


def failure_like(result: dict[str, Any]) -> bool:
    if result["exit_code"] != 0:
        return True
    stdout_text = (result.get("stdout") or "").lower()
    stderr_text = (result.get("stderr") or "").lower()
    soft_failure_markers = [
        "could not complete",
        "cannot complete",
        "can't complete",
        "unable to complete",
        "ran into this error",
        "execution error:",
    ]
    hard_error_markers = [
        "permission denied",
        "timed out",
        "unexpected argument",
        "usage:",
        "not logged in",
    ]
    if any(marker in stdout_text for marker in soft_failure_markers):
        return True
    if stdout_text.strip():
        return False
    return any(marker in stderr_text for marker in hard_error_markers)


def summarize_result(result: dict[str, Any]) -> str:
    output = result.get("stdout") or result.get("stderr") or ""
    output = re.sub(r"\x1b\[[0-9;]*m", "", str(output))
    output = output.strip()
    if len(output) > 1400:
        output = output[:1397] + "..."
    return output


def _job_path(job_id: str) -> Path:
    return JOBS_DIR / f"{job_id}.json"


def load_job(job_id: str) -> dict[str, Any]:
    return json.loads(_job_path(job_id).read_text(encoding="utf-8"))


def save_job(job: dict[str, Any]) -> str:
    ensure_state_root()
    path = _job_path(job["job_id"])
    with tempfile.NamedTemporaryFile("w", delete=False, dir=JOBS_DIR, encoding="utf-8") as handle:
        json.dump(job, handle, indent=2)
        handle.flush()
        temp_path = Path(handle.name)
    temp_path.replace(path)
    return str(path)


def collect_result(
    worker: str,
    command: list[str],
    cwd: str,
    timeout: int,
    job_id: str,
    attempt_index: int,
) -> dict[str, Any]:
    started = now_ts()
    log_path = LOGS_DIR / f"{job_id}-{attempt_index:02d}-{worker}.log"
    with log_path.open("w", encoding="utf-8") as log_handle:
        proc = subprocess.Popen(
            command,
            stdout=log_handle,
            stderr=subprocess.STDOUT,
            text=True,
            cwd=cwd,
            start_new_session=True,
        )
        try:
            exit_code = proc.wait(timeout=timeout)
        except subprocess.TimeoutExpired:
            try:
                if proc.poll() is None:
                    os.killpg(proc.pid, signal.SIGTERM)
            except Exception:
                try:
                    proc.kill()
                except Exception:
                    pass
            try:
                proc.wait(timeout=5)
            except Exception:
                pass
            exit_code = 124
            log_handle.write("\n[ai-dispatch] timed out\n")
    ended = now_ts()
    combined = log_path.read_text(encoding="utf-8", errors="replace") if log_path.exists() else ""
    return {
        "worker": worker,
        "command": command,
        "exit_code": exit_code,
        "duration_seconds": round(ended - started, 2),
        "stdout": combined.strip() if exit_code == 0 else "",
        "stderr": "" if exit_code == 0 else combined.strip(),
        "ok": exit_code == 0,
        "log_path": str(log_path),
    }


def run_sync(job: dict[str, Any]) -> dict[str, Any]:
    attempts: list[dict[str, Any]] = []
    winner: dict[str, Any] | None = None
    for index, worker in enumerate(job["route"]):
        prompt = build_prompt(job["task"], job["difficulty"], job["cwd"], job["from_agent"], worker)
        try:
            command = worker_command(worker, prompt, job["cwd"], job["from_agent"], job["difficulty"])
            result = collect_result(worker, command, job["cwd"], int(job["timeout"]), job["job_id"], index)
        except Exception as exc:
            result = {
                "worker": worker,
                "command": [],
                "exit_code": 2,
                "duration_seconds": 0,
                "stdout": "",
                "stderr": str(exc),
                "ok": False,
                "log_path": "",
            }
        attempts.append(result)
        if not failure_like(result):
            winner = result
            break
    job["attempts"] = attempts
    job["winner"] = winner["worker"] if winner else None
    job["success"] = winner is not None
    job["status"] = "completed" if winner else "failed"
    job["finished_at"] = now_ts()
    save_job(job)
    return job


def spawn_monitor(job: dict[str, Any]) -> None:
    subprocess.Popen(
        [sys.executable, __file__, "__monitor__", job["job_id"]],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        stdin=subprocess.DEVNULL,
        cwd=job["cwd"],
        start_new_session=True,
        env=os.environ.copy(),
    )


def run_monitor(job_id: str) -> int:
    job = load_job(job_id)
    job["status"] = "running"
    job["started_at"] = now_ts()
    save_job(job)
    run_sync(job)
    return 0


def create_job(args: argparse.Namespace) -> dict[str, Any]:
    task = " ".join(args.task).strip()
    cwd = os.path.abspath(os.path.expanduser(args.cwd))
    repo_root = detect_repo_root(cwd)
    if repo_root:
        cwd = repo_root
    difficulty = normalize_difficulty(args.difficulty, task)
    route = route_for(args.target, difficulty)
    session_key = args.session_key or os.environ.get("AI_PEERS_SESSION_KEY", "").strip()
    job = {
        "job_id": uuid.uuid4().hex[:12],
        "target": args.target,
        "from_agent": args.from_agent,
        "session_key": session_key,
        "notify_on_complete": bool(args.notify_on_complete),
        "difficulty": difficulty,
        "cwd": cwd,
        "task": task,
        "route": route,
        "timeout": int(args.timeout),
        "created_at": now_ts(),
        "started_at": None,
        "finished_at": None,
        "status": "queued",
        "winner": None,
        "success": False,
        "attempts": [],
        "completion_seen_at": None,
    }
    save_job(job)
    return job


def format_started(job: dict[str, Any]) -> str:
    return (
        f"[ai-dispatch] started background job={job['job_id']} route={','.join(job['route'])} "
        f"difficulty={job['difficulty']} job_file={_job_path(job['job_id'])}"
    )


def poll_completions(session_key: str, limit: int = 8, mark_seen: bool = True) -> dict[str, Any]:
    ensure_state_root()
    matches: list[dict[str, Any]] = []
    for path in sorted(JOBS_DIR.glob("*.json"), key=lambda p: p.stat().st_mtime):
        try:
            job = json.loads(path.read_text(encoding="utf-8"))
        except Exception:
            continue
        if session_key and job.get("session_key") != session_key:
            continue
        if not job.get("notify_on_complete"):
            continue
        if job.get("status") not in {"completed", "failed"}:
            continue
        if job.get("completion_seen_at"):
            continue
        matches.append(job)
    matches = matches[: max(1, min(limit, 100))]
    if mark_seen and matches:
        seen_at = now_ts()
        for job in matches:
            job["completion_seen_at"] = seen_at
            save_job(job)
    return {"jobs": matches}


def job_status(job_id: str) -> dict[str, Any]:
    return load_job(job_id)


def parse_dispatch_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(prog="ai-dispatch")
    parser.add_argument(
        "--target",
        default="auto",
        help="Explicitly target one worker, or use auto routing.",
    )
    parser.add_argument(
        "--difficulty",
        choices=["easy", "hard", "auto"],
        default="auto",
        help="Used by auto routing. Easy prefers OpenCode first; hard prefers Cursor first.",
    )
    parser.add_argument("--cwd", default=os.getcwd(), help="Working directory for the delegated worker.")
    parser.add_argument("--timeout", type=int, default=DEFAULT_TIMEOUT, help="Per-worker timeout in seconds.")
    parser.add_argument("--json", action="store_true", help="Emit full JSON instead of a human summary.")
    parser.add_argument(
        "--from-agent",
        default=os.environ.get("AI_DISPATCH_SOURCE", "unknown-agent"),
        help="Name of the calling agent for prompt context.",
    )
    parser.add_argument("--background", action="store_true", help="Run the delegation job in the background.")
    parser.add_argument(
        "--notify-on-complete",
        action="store_true",
        help="If backgrounded, queue a completion notice for the calling agent session.",
    )
    parser.add_argument(
        "--session-key",
        default=os.environ.get("AI_PEERS_SESSION_KEY", ""),
        help="Stable session key for completion notifications.",
    )
    parser.add_argument("task", nargs="+", help="Task prompt to delegate.")
    args = parser.parse_args(argv)
    args.subcommand = None
    return args


def parse_special_args(argv: list[str]) -> argparse.Namespace:
    subcommand = argv[0]
    parser = argparse.ArgumentParser(prog=f"ai-dispatch {subcommand}")
    if subcommand == "__monitor__":
        parser.add_argument("job_id")
    elif subcommand == "poll-completions":
        parser.add_argument("--session-key", default=os.environ.get("AI_PEERS_SESSION_KEY", ""))
        parser.add_argument("--limit", type=int, default=8)
        parser.add_argument("--keep-unseen", action="store_true")
    elif subcommand == "job-status":
        parser.add_argument("job_id")
    else:
        raise SystemExit(f"Unknown subcommand: {subcommand}")
    args = parser.parse_args(argv[1:])
    args.subcommand = subcommand
    return args


def main() -> int:
    argv = sys.argv[1:]
    special = {"__monitor__", "poll-completions", "job-status"}
    args = parse_special_args(argv) if argv and argv[0] in special else parse_dispatch_args(argv)
    ensure_state_root()

    if args.subcommand == "__monitor__":
        return run_monitor(args.job_id)

    if args.subcommand == "poll-completions":
        payload = poll_completions(
            session_key=args.session_key.strip(),
            limit=int(args.limit),
            mark_seen=not args.keep_unseen,
        )
        print(json.dumps(payload, indent=2))
        return 0

    if args.subcommand == "job-status":
        print(json.dumps(job_status(args.job_id), indent=2))
        return 0

    if not args.task:
        raise SystemExit("Missing task prompt.")

    job = create_job(args)

    if args.background:
        spawn_monitor(job)
        if args.json:
            print(json.dumps(job, indent=2))
        else:
            print(format_started(job))
        return 0

    job["status"] = "running"
    job["started_at"] = now_ts()
    save_job(job)
    job = run_sync(job)
    if args.json:
        print(json.dumps(job, indent=2))
        return 0 if job["success"] else 1
    if job["success"]:
        winner = next(attempt for attempt in job["attempts"] if attempt["worker"] == job["winner"])
        print(
            f"[ai-dispatch] winner={winner['worker']} difficulty={job['difficulty']} job_file={_job_path(job['job_id'])}\n"
            f"{summarize_result(winner)}"
        )
        return 0
    detail = summarize_result(job["attempts"][0]) if job["attempts"] else ""
    print(
        f"[ai-dispatch] all delegated workers failed difficulty={job['difficulty']} job_file={_job_path(job['job_id'])}\n"
        f"{detail}\nThe calling agent should handle this task directly."
    )
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
